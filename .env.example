# ─────────────────────────────────────────────────────────────
# Claude: the brain. Get a key at https://console.anthropic.com
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model + effort. Leave these unless you know you want to change them.
AGENT_MODEL=claude-opus-4-8
AGENT_EFFORT=high

# ─────────────────────────────────────────────────────────────
# MetadataONE MCP: the wiring to your ad accounts
# (LinkedIn, Meta, Google, Reddit, X: all five through one server)
# Generate the token in Metadata under Settings → Access Token.
# ─────────────────────────────────────────────────────────────
METADATAONE_MCP_URL=https://mcp-server.metadata.io/mcp
METADATAONE_TOKEN=

# The real MetadataONE MCP tool names the agent drives (from help.metadata.io,
# "Metadata MCP - Supported Tools": 70 tools / 14 categories). Run `npm run probe`
# to confirm them against your own tenant, then override here only if needed.
MCP_TOOL_PERFORMANCE=performance_metrics
MCP_TOOL_MANAGE_CAMPAIGN=manage_campaign
MCP_TOOL_UPDATE_BUDGETS=update_experiments_daily_budgets

# ─────────────────────────────────────────────────────────────
# Slack: where you talk to the agent and approve the big moves
# Create an app at https://api.slack.com/apps (Socket Mode on).
#   Bot token  → OAuth & Permissions   (xoxb-…)
#   App token  → Basic Information      (xapp-…, connections:write)
#   Signing secret → Basic Information
# ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
# The channel the agent posts alerts and the weekly readout to.
SLACK_CHANNEL=#paid-media
# Dashboard link the agent drops into Slack ("Full picture: …"). Deploy the
# site/ folder and paste its /dashboard URL, or leave blank.
DASHBOARD_URL=

# ─────────────────────────────────────────────────────────────
# Guardrails: what the agent can do on its own vs. what needs you
# ─────────────────────────────────────────────────────────────
# Budget moves at or under this daily amount execute automatically.
# Anything larger is posted to Slack and waits for your approval.
AUTO_APPROVE_DAILY_USD=2000
# Hard ceiling: the agent will never propose a single move above this.
MAX_DAILY_SHIFT_USD=20000
# CPL ceiling. When a channel's CPL crosses this, the guard kicks in.
CPL_CEILING_USD=140

# ─────────────────────────────────────────────────────────────
# Schedules (cron). Defaults: pace check every 15 min on the hour's
# quarters during the day; weekly readout Monday 9am.
# ─────────────────────────────────────────────────────────────
PACING_CRON=*/15 7-19 * * 1-5
WEEKLY_CRON=0 9 * * 1
TIMEZONE=America/New_York
