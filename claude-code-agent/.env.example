# No Anthropic API key. This build runs on your Claude subscription via Claude
# Code. Log in once with:  claude login

# ── MetadataONE: all ad work happens here, through its MCP ────────────────────
# Metadata: Settings, Access Token, Generate Access Token for MCP Server.
METADATAONE_TOKEN=

# ── Slack: the agent posts alerts and reads your instructions through a Slack MCP
# Create an app at api.slack.com/apps. Bot scopes: chat:write, channels:history,
# channels:read, groups:history. Install it, then invite it to your channel.
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T0XXXXXXXX
SLACK_CHANNEL=#paid-media

# Dashboard link the agent drops into Slack ("Full picture: ...").
DASHBOARD_URL=

# ── Guardrails: the agent is told these each run and follows them ─────────────
AUTO_APPROVE_DAILY_USD=2000
MAX_DAILY_SHIFT_USD=20000
CPL_CEILING_USD=140
